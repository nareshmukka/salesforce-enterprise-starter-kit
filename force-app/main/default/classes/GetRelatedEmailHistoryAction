/**
 * Description: Agent action that retrieves recent EmailMessage history for a Case.
 * Developer: Naresh
 * Title: Senior Salesforce Developer
 */
public with sharing class GetRelatedEmailHistoryAction {
    /**
     * Description: Request payload for retrieving email history.
     * Developer: Naresh
     * Title: Senior Salesforce Developer
     */
    public class Request {
        @InvocableVariable(required=true)
        public Id caseId;
    }

    /**
     * Description: Email history row returned to the agent.
     * Developer: Naresh
     * Title: Senior Salesforce Developer
     */
    public class EmailHistoryItem {
        @InvocableVariable public String emailSubject;
        @InvocableVariable public String emailBody;
        @InvocableVariable public String emailDirection;
        @InvocableVariable public Datetime emailCreatedDate;
    }

    /**
     * Description: Response payload containing related email history.
     * Developer: Naresh
     * Title: Senior Salesforce Developer
     */
    public class Response {
        @InvocableVariable public List<EmailHistoryItem> history;
    }

    /**
     * Description: Retrieves recent EmailMessage history for agent reasoning.
     * @param requests Action requests.
     * @return List<Response> History responses.
     * Developer: Naresh
     * Title: Senior Salesforce Developer
     */
    @InvocableMethod(
        label='Get Related Email History'
        description='Retrieves recent EmailMessage history related to the Case.'
    )
    public static List<Response> execute(List<Request> requests) {
        List<Response> responses = new List<Response>();
        if (requests == null || requests.isEmpty()) {
            return responses;
        }

        Set<Id> caseIds = new Set<Id>();
        for (Request request : requests) {
            if (request.caseId != null) {
                caseIds.add(request.caseId);
            }
        }

        Map<Id, List<EmailHistoryItem>> historyByCaseId = new Map<Id, List<EmailHistoryItem>>();
        for (Id caseId : caseIds) {
            historyByCaseId.put(caseId, new List<EmailHistoryItem>());
        }

        for (EmailMessage email : [
            SELECT ParentId, Subject, TextBody, Incoming, CreatedDate
            FROM EmailMessage
            WHERE ParentId IN :caseIds
            ORDER BY CreatedDate DESC
            LIMIT 50
        ]) {
            if (!historyByCaseId.containsKey(email.ParentId)) {
                continue;
            }

            List<EmailHistoryItem> rows = historyByCaseId.get(email.ParentId);
            if (rows.size() >= 10) {
                continue;
            }

            EmailHistoryItem row = new EmailHistoryItem();
            row.emailSubject = email.Subject;
            row.emailBody = email.TextBody;
            row.emailDirection = email.Incoming ? 'Inbound' : 'Outbound';
            row.emailCreatedDate = email.CreatedDate;
            rows.add(row);
        }

        for (Request request : requests) {
            Response response = new Response();
            response.history = historyByCaseId.containsKey(request.caseId)
                ? historyByCaseId.get(request.caseId)
                : new List<EmailHistoryItem>();
            responses.add(response);
        }

        return responses;
    }
}